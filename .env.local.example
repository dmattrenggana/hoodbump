# ============================================
# HoodBump - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in your actual values

# ============================================
# Privy Configuration
# ============================================
# Get your Privy App ID from: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# ============================================
# Robinhood Chain Configuration
# ============================================
# Public RPC (rate-limited, for dev only)
NEXT_PUBLIC_HOODBUMP_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Alchemy RPC (recommended for production, get API key from alchemy.com)
NEXT_PUBLIC_HOODBUMP_ALCHEMY_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# WebSocket RPC (for event listening)
NEXT_PUBLIC_HOODBUMP_WS_URL=wss://robinhood-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
